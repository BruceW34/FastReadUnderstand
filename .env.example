# FIREBASE CONFIG - GÜVENLI PRODUCTION DEPLOYMENT İÇİN
# Firebase Console'dan alınan değerleri buraya kopyala
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# ADMOB CONFIG - PRODUCTION AD UNIT IDs
# AdMob Console'dan alınan production unit ID'leri buraya kopyala
VITE_ADMOB_REWARD_AD_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxx
VITE_ADMOB_INTERSTITIAL_AD_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxx
VITE_ADMOB_BANNER_AD_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxx

# APP CONFIG
VITE_ENVIRONMENT=production
VITE_APP_VERSION=2.0.0

# FEATURE FLAGS
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_LOGGING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# API ENDPOINTS (ihtiyaç duyarsa)
# VITE_API_BASE_URL=https://api.example.com
