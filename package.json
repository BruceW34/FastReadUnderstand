{
  "name": "fastread",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "license": "MIT",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist:win": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.fastread.app",
    "productName": "FastRead",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "main.cjs"
    ]
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "firebase": "^12.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2",
    "terser": "^5.46.1",
    "typescript": "^5.7.0",
    "vite": "^5.0.0"
  }
}
